# Django
DEBUG=True
SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=rabivault
POSTGRES_USER=rabivault_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# MinIO root user used by the MinIO container
MINIO_ROOT_USER=rabivault_minio
MINIO_ROOT_PASSWORD=change-me

# Main document bucket. Keep this identical to AWS_STORAGE_BUCKET_NAME.
MINIO_BUCKET_NAME=rabivault-files

# Django S3/MinIO storage settings
AWS_ACCESS_KEY_ID=rabivault_minio
AWS_SECRET_ACCESS_KEY=change-me
AWS_STORAGE_BUCKET_NAME=rabivault-files
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1

# ClamAV
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# Orthanc
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=change-me
ORTHANC_AET=RABIVAULT
